{
  "name": "pi-native-search",
  "version": "0.1.0",
  "private": false,
  "description": "Pi extension that adds web_search and web_fetch tools using each provider's native search backend (ZAI MCP, Anthropic, Google, OpenAI, xAI, Claude Code subscription via claude-bridge), with DuckDuckGo as a universal fallback.",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "web-search",
    "web-fetch",
    "claude",
    "claude-code",
    "glm",
    "duckduckgo"
  ],
  "author": "Salem Malibary <salem.thecreativeconsult@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yiwenlu66/pi-native-search.git"
  },
  "homepage": "https://github.com/yiwenlu66/pi-native-search#readme",
  "bugs": {
    "url": "https://github.com/yiwenlu66/pi-native-search/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "peerDependenciesMeta": {
    "pi-claude-bridge": {
      "optional": true
    }
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  }
}
